# ── Server ────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# ENV=development  # set to "development" for hot-reload; defaults to "production"

# ── Database (PostgreSQL) ────────────────────────────────────────────────
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quickstock
# Supabase (use Session pooler or Direct connection — NOT Transaction pooler):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Bolna ─────────────────────────────────────────────────────────────────
# Get from: https://app.bolna.dev → Settings → API Keys
BOLNA_API_KEY=your_bolna_api_key_here

# Your agent ID from Bolna (created on the website)
BOLNA_AGENT_ID=your_bolna_agent_id_here

# Your public webhook URL — Bolna will POST call results here
# Use ngrok during dev: ngrok http 8000 → copy the https URL
BOLNA_SERVER_URL=https://your-public-url.ngrok.io

# ── Azure OpenAI ─────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://az-openai-shared.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.3

# ── Google ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# ── Limits ───────────────────────────────────────────────────────────────
MAX_STORES_TO_CALL=4

# ── Test Mode ─────────────────────────────────────────────────────────────
# Set TEST_MODE=true and TEST_PHONE to your own number to test without calling real stores
TEST_MODE=false
TEST_PHONE=+91
